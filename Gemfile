source "https://rubygems.org"

# Tracks the Jekyll + plugin versions GitHub Pages uses, so local builds match
# what ships to the live site.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-feed"
end

gem "webrick", "~> 1.8"
